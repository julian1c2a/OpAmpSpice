* Etapas diferenciales primeras, con salidas diferenciales, con Ganancia ajustable como parámetro.

.include OpAmp.cir

* ====================================================================
* ETAPA GENÉRICA (Usa el modelo idealizado base)
* ====================================================================
.subckt Diff_In_Diff_Out_stage_amp inp+ inn+ outp outn vcc vee gnd PARAMS: Av=1000

* Seleccionamos Rp y Rn de forma dinámica usando condicionales ternarios
* Si Av >= 1000, Rp = 10k. Si Av <= 100, Rp = 1k. En medio, Rp = Av * 10.
.param Rp_val={ Av >= 1000 ? 10k : (Av <= 100 ? 1k : Av * 10) }
.param Rn_val={ Rp_val }

* Calculamos Rg. Prevenimos una división por cero si el usuario pide Av=1 (buffer)
.param Rg_val={ Av <= 1.001 ? 1000G : (2 * Rp_val / (Av - 1)) }

Xp inp+ inp- outp vcc vee gnd OpAmp
Xn inn+ inn- outn vcc vee gnd OpAmp
Rp inp- outp {Rp_val}
Rn inn- outn {Rn_val}
Rg inp- inn- {Rg_val}

.ends Diff_In_Diff_Out_stage_amp


* ====================================================================
* LIBRERÍA DE ETAPAS DIFERENCIALES CON OPAMPS COMERCIALES
* ====================================================================

* LM741 (Propósito General)
.subckt diffdiff_LM741 inp+ inn+ outp outn vcc vee gnd PARAMS: Av=1000
.param Rp_val={ Av >= 1000 ? 10k : (Av <= 100 ? 1k : Av * 10) }
.param Rn_val={ Rp_val }
.param Rg_val={ Av <= 1.001 ? 1000G : (2 * Rp_val / (Av - 1)) }
Xp inp+ inp- outp vcc vee gnd LM741
Xn inn+ inn- outn vcc vee gnd LM741
Rp inp- outp {Rp_val}
Rn inn- outn {Rn_val}
Rg inp- inn- {Rg_val}
.ends diffdiff_LM741

